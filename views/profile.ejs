<%- include('./partials/sidenavheader.ejs') %>
    <main class="profile-main center-align" role="main" aria-labelledby="profile-heading">
        <%- include('./partials/flash.ejs') %>
        <div class="container center-align">
            <section class="container center-align" aria-labelledby="profile-heading">
                <h2 id="profile-heading" class="sr-only">Profile Information</h2>
                <div class="card z-depth-1">
                    <div class="card-content center-align">
                        <img src="<%= user.image || '/imgs/default-avatar.png' %>" class="circle profile-image" alt="User profile image">
                        <div class="file-field input-field file-field-inline">
                            <div class="btn blue-grey waves-effect waves-light hoverable btn-transition">
                                <span>Upload Picture</span>
                                <input type="file" id="profile-picture" accept="image/*" aria-label="Upload profile picture">
                            </div>
                            <div class="file-path-wrapper">
                                <input class="file-path validate" type="text" aria-label="Selected file path">
                            </div>
                        </div>
                        <button id="upload-btn" class="btn blue-grey waves-effect waves-light hoverable" aria-label="Update Picture" class="btn-margin-left btn-transition">Update Picture</button>
                        <div id="upload-preloader" class="preloader-wrapper small active upload-preloader">
                                <div class="spinner-layer spinner-blue-only">
                                <div class="circle-clipper left">
                                    <div class="circle"></div>
                                </div>
                                <div class="gap-patch">
                                    <div class="circle"></div>
                                </div>
                                <div class="circle-clipper right">
                                    <div class="circle"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
            <section class="container center-align" aria-labelledby="profile-info-heading">
                    <h2 id="profile-info-heading" class="sr-only">Profile Details</h2>
                <div class="card z-depth-1">
                    <div class="card-content center-align">
                        <h3>Profile Information</h3>
                        <p><strong>Username:</strong> <%= user.username %></p>
                        <p><strong>Email:</strong> <%= user.email %></p>
                        <p><strong>Role:</strong> <%= user.role %></p>
                        <p><strong>Member Since:</strong> <%= moment(user.createdAt).format('MMMM Do YYYY') %></p>
                        <form action="/profile/edit/<%=user._id%>" method="GET" class="form-inline">
                            <button type="submit" class="btn blue-grey waves-effect waves-light hoverable" aria-label="Edit Profile" class="btn-margin-top btn-transition">Edit Profile</button>
                        </form>
                        <form action="/profile/delete/<%=user._id%>?_method=DELETE" method="POST" class="form-inline btn-margin-top-left" onsubmit="return confirm('Are you sure you want to delete your profile? This action cannot be undone.');">
                            <button type="submit" class="btn red waves-effect waves-light hoverable" aria-label="Delete Profile" class="btn-margin-top btn-transition">Delete Profile</button>
                        </form>
                    </div>
                </div>
            </section>
            <section class="container center-align" aria-labelledby="other-users-heading">
                <h2 id="other-users-heading" class="sr-only">Other Users</h2>
                <div class="card z-depth-1">
                    <div class="card-content center-align">
                        <h3>Other Users</h3>
                        <% if (users && users.length > 0) { %>
                            <% users.forEach(user => { %>
                                <div class="card-panel">
                                    <p><span class="bold"><%= user.username %></span></p>
                                    <p><span><%= user.email %></span></p>
                                    <p><%= user.role %></p>
                    </div>
                            <% }) %>
                        <% } else { %>
                            <p>No other users found.</p>
                        <% } %>
                    </div>
                </div>
            </section>
            <button data-confetti="true"></button>
        </div>
    </main>
<%- include('./partials/sidenavfooter.ejs') %>