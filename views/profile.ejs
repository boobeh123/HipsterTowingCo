<%- include('./partials/head.ejs') %>
<%- include('./partials/header.ejs') %>

<main id="main-content" class="profilePage" tabindex="-1" aria-labelledby="profilePage-heading">
    <div class="profilePage__inner">

        <%- include('./partials/flash.ejs') %>

        <header class="profilePage__header">
            <div class="profilePage__headerNav">
                <a href="/dashboard" class="profilePage__back">&#8592; Dashboard</a>
            </div>
            <h1 id="profilePage-heading" class="profilePage__title">Profile</h1>
        </header>

        <!-- Photo section -->
        <section class="profileCard" aria-labelledby="photo-heading">
            <h2 id="photo-heading" class="profileCard__title">Photo</h2>

            <div class="profileCard__photoRow">
                <img
                    src="<%= user.image || 'https://placeholder.pics/svg/80x80' %>"
                    alt="Profile photo for <%= user.email %>"
                    class="profileCard__avatar"
                    width="80"
                    height="80"
                />
                <form
                    class="profileCard__uploadForm"
                    action="/profile/photo"
                    method="POST"
                    enctype="multipart/form-data"
                    aria-label="Upload profile photo"
                >
                    <label for="profile-file" class="profileCard__fileLabel">
                        Choose photo
                        <input
                            id="profile-file"
                            type="file"
                            name="file"
                            accept=".jpg,.jpeg,.png"
                            required
                            class="profileCard__fileInput"
                        />
                    </label>
                    <button type="submit" class="btn btn--primary profileCard__uploadBtn">
                        Upload
                    </button>
                    <p class="profileCard__fileHint">JPG or PNG, square crop applied automatically</p>
                </form>
            </div>
        </section>

        <!-- Account info section -->
        <section class="profileCard" aria-labelledby="account-heading">
            <h2 id="account-heading" class="profileCard__title">Account</h2>

            <dl class="profileCard__dl">
                <div class="profileCard__row">
                    <dt class="profileCard__dt">Email</dt>
                    <dd class="profileCard__dd"><%= user.email %></dd>
                </div>
                <div class="profileCard__row">
                    <dt class="profileCard__dt">Role</dt>
                    <dd class="profileCard__dd"><%= user.role || 'user' %></dd>
                </div>
                <div class="profileCard__row">
                    <dt class="profileCard__dt">Member since</dt>
                    <dd class="profileCard__dd">
                        <%= new Date(user.createdAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %>
                    </dd>
                </div>
            </dl>

            <div class="profileCard__actions">
                <a href="/forgot" class="btn btn--secondary">Change password</a>
            </div>
        </section>

        <!-- Danger zone -->
        <section class="profileCard profileCard--danger" aria-labelledby="danger-heading">
            <h2 id="danger-heading" class="profileCard__title profileCard__title--danger">Danger zone</h2>
            <p class="profileCard__dangerText">Deleting your account is permanent. All your inspections will also be deleted and cannot be recovered.</p>
            <form
                action="/profile/delete?_method=DELETE"
                method="POST"
                onsubmit="return confirm('Are you sure? This will permanently delete your account and all your inspections.')"
            >
                <button type="submit" class="btn profileCard__deleteBtn">Delete account</button>
            </form>
        </section>

    </div>
</main>

<%- include('./partials/footer.ejs') %>
