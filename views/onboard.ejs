<%- include('./partials/head.ejs') %>
<%- include('./partials/header.ejs') %>

<main id="main-content" class="authPage authPage--centered" tabindex="-1" aria-labelledby="authPage-heading">

    <div class="authPage__panel">
        <div class="authPage__formWrap">

            <div aria-live="polite" aria-atomic="true">
                <%- include('./partials/flash.ejs') %>
            </div>

            <header class="authPage__formHeader">
                <h1 id="authPage-heading" class="authPage__title">What should we call you?</h1>
                <p class="authPage__subtitle">Add your name to finish setting up your account.</p>
            </header>

            <form class="authPage__form" action="/onboard" method="POST" aria-labelledby="authPage-heading" novalidate>

                <div class="authPage__field">
                    <label for="onboard-name" class="authPage__label">Your name</label>
                    <input
                        id="onboard-name"
                        class="authPage__input"
                        type="text"
                        name="name"
                        autocomplete="name"
                        maxlength="60"
                        required
                        autofocus
                    />
                </div>

                <button type="submit" class="btn btn--primary authPage__submit">Continue to dashboard</button>

            </form>

        </div>
    </div>

</main>

<%- include('./partials/footer.ejs') %>
