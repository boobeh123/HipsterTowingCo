<%- include('./partials/head.ejs') %>
<%- include('./partials/header.ejs') %>

<main id="main-content" class="authPage" tabindex="-1" aria-labelledby="authPage-heading">

    <!-- Brand panel -->
    <div class="authPage__brand" aria-hidden="true">
        <div class="authPage__brandInner">
            <svg
                class="authPage__brandMark"
                width="96"
                height="96"
                viewBox="0 0 64 64"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                focusable="false"
            >
                <text
                    x="8"
                    y="48"
                    font-family="Roboto, system-ui, sans-serif"
                    font-size="48"
                    font-weight="700"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                >q</text>
                <text
                    x="32"
                    y="48"
                    font-family="Roboto, system-ui, sans-serif"
                    font-size="48"
                    font-weight="700"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                >p</text>
            </svg>
            <p class="authPage__brandName">pretriq</p>
            <p class="authPage__brandTagline">Your inspection history,<br>ready when you are.</p>
        </div>
    </div>

    <!-- Form panel -->
    <div class="authPage__panel">
        <div class="authPage__formWrap">

            <div aria-live="polite" aria-atomic="true">
                <%- include('./partials/flash.ejs') %>
            </div>

            <header class="authPage__formHeader">
                <h1 id="authPage-heading" class="authPage__title">Log in</h1>
                <p class="authPage__subtitle">Don't have an account? <a href="/signup">Sign up</a></p>
            </header>

            <form class="authPage__form" action="/login" method="POST" aria-labelledby="authPage-heading" novalidate>

                <div class="authPage__field">
                    <label for="login-email" class="authPage__label">Email address</label>
                    <input
                        id="login-email"
                        class="authPage__input"
                        type="email"
                        name="email"
                        autocomplete="email"
                        required
                        autofocus
                    />
                </div>

                <div class="authPage__field">
                    <div class="authPage__labelRow">
                        <label for="login-password" class="authPage__label">Password</label>
                        <a href="/forgot" class="authPage__forgotLink">Forgot password?</a>
                    </div>
                    <input
                        id="login-password"
                        class="authPage__input"
                        type="password"
                        name="password"
                        autocomplete="current-password"
                        required
                    />
                </div>

                <button type="submit" class="btn btn--primary authPage__submit">Log in</button>

            </form>

        </div>
    </div>

</main>

<%- include('./partials/footer.ejs') %>
