<header class="site-header<%= locals.currentPath !== '/' ? ' site-header--interior' : '' %>">
    <div class="site-header__inner">
        <a href="/" class="site-header__brand" aria-label="Pretriq Home">
            <svg
                class="site-header__logo"
                width="56"
                height="56"
                viewBox="0 0 64 64"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
                focusable="false"
            >
                <text
                    x="8"
                    y="48"
                    font-family="Roboto, system-ui, sans-serif"
                    font-size="48"
                    font-weight="700"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                >q</text>
                <text
                    x="32"
                    y="48"
                    font-family="Roboto, system-ui, sans-serif"
                    font-size="48"
                    font-weight="700"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                >p</text>
            </svg>
        </a>
        <nav class="site-header__nav" aria-label="Main navigation">
            <% if (user) { %>
                <div class="site-header__userNav">
                    <button
                        type="button"
                        class="site-header__avatarBtn"
                        id="userNavToggle"
                        aria-expanded="false"
                        aria-controls="userNavMenu"
                        aria-label="Open user menu"
                    >
                        <% if (user.image) { %>
                            <img
                                src="<%= user.image %>"
                                alt="<%= user.name || user.email %> profile photo"
                                class="site-header__avatar"
                            />
                        <% } else { %>
                            <span class="site-header__avatarFallback" aria-hidden="true"><%= (user.name || user.email).charAt(0).toUpperCase() %></span>
                        <% } %>
                    </button>
                    <div
                        id="userNavMenu"
                        class="site-header__userMenu"
                        aria-hidden="true"
                    >
                        <a
                            href="/dashboard"
                            class="site-header__menuLink<%= (locals.currentPath || '') === '/dashboard' ? ' site-header__menuLink--active' : '' %>"
                            <%= (locals.currentPath || '') === '/dashboard' ? 'aria-current="page"' : '' %>
                        >Dashboard</a>
                        <a
                            href="/profile"
                            class="site-header__menuLink<%= (locals.currentPath || '') === '/profile' ? ' site-header__menuLink--active' : '' %>"
                            <%= (locals.currentPath || '') === '/profile' ? 'aria-current="page"' : '' %>
                        >Profile</a>
                        <a href="/logout" class="site-header__menuLink">Log out</a>
                    </div>
                </div>
            <% } else { %>
                <a href="/login" class="btn btn--nav">Log in</a>
            <% } %>
        </nav>
    </div>
</header>
