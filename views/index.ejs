<%- include('./partials/head.ejs') %>
<%- include('./partials/header.ejs') %>
<%- include('./partials/inspectionModal.ejs') %>

    <main id="main-content" class="page-home" tabindex="-1">
        <section class="hero" aria-labelledby="hero-heading">
            <div class="hero__canvas" aria-hidden="true">
                <canvas id="hero-particles" width="300" height="150"></canvas>
            </div>
            <div class="hero__inner">
                <div class="hero__copy">
                    <h1 id="hero-heading" class="hero__title">
                        Welcome to <strong class="hero__brand">pretriq</strong>
                    </h1>
                    <p class="hero__lead">
                        Partial functionality is available to users. Full functionality will be restored soon. Digital pretrip inspections is under maintenance. 
                    </p>
                    <div class="hero__actions">
                        <div class="animated-button-container">
                            <button
                                type="button"
                                id="startInspectionBtn"
                                class="btn btn--primary animated-button"
                                aria-haspopup="dialog"
                                aria-label="Start a new pretrip report"
                            >
                                <span class="btn__icon" aria-hidden="true">&#9654;</span>
                                Start pretrip
                            </button>
                        </div>
                    </div>
                </div>

                <div class="hero__media">
                    <img
                        src="/imgs/hero.webp"
                        alt="Digital truck with inspection dashboard"
                        class="hero__image"
                        decoding="async"
                    />
                </div>
            </div>
        </section>
    </main>
<%- include('./partials/footer.ejs') %>
